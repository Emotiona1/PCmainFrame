{
  "name": "we-agent-web",
  "version": "1.0.0",
  "private": true,
  "description": "A simple PC chat front-end built with React and Webpack 5.",
  "main": "dist/weAgent/index.js",
  "files": [
    "dist/weAgent",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "webpack --mode development --watch",
    "preview": "webpack serve --config webpack.preview.config.js --mode development",
    "preview:build": "webpack --config webpack.preview.config.js --mode production",
    "build": "webpack --mode production",
    "verify": "npm run build && node scripts/verify-build.mjs"
  },
  "dependencies": {
    "antd": "^6.3.5",
    "react": "^18.3.1"
  },
  "peerDependencies": {
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/preset-react": "^7.24.7",
    "babel-loader": "^9.1.3",
    "copy-webpack-plugin": "^12.0.2",
    "css-loader": "^7.1.2",
    "html-webpack-plugin": "^5.6.0",
    "path-browserify": "^1.0.1",
    "react-dom": "^18.3.1",
    "style-loader": "^4.0.0",
    "webpack": "^5.94.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.0.4"
  }
}
